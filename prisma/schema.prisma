generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

/// Üst düzey koleksiyon (ör. Oturma Odası, Yatak Odası)
model Collection {
  id            String    @id @default(cuid())
  slug          String    @unique
  name          String
  nameEn        String?
  description   String?   @db.Text
  descriptionEn String?   @db.Text
  coverImage  String?
  sortOrder   Int       @default(0)
  isPublished Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  products Product[]

  @@index([isPublished, sortOrder])
  @@map("collections")
}

/// Katalog ürünü
model Product {
  id            String   @id @default(cuid())
  slug          String   @unique
  name          String
  nameEn        String?
  description   String?  @db.Text
  descriptionEn String?  @db.Text
  /// Serbest metin ölçü özeti (ör. "240 x 90 x 75 cm")
  dimensions      String?
  /// Parça bazlı ölçü ve fiyat tablosu: [{ name?, nameEn?, widthCm, depthCm, heightCm, amount?, quantity? }]
  dimensionItems  Json?
  widthCm         Decimal? @db.Decimal(8, 2)
  heightCm        Decimal? @db.Decimal(8, 2)
  depthCm         Decimal? @db.Decimal(8, 2)
  sortOrder      Int      @default(0)
  isPublished    Boolean  @default(true)
  /// Anasayfa vitrininde gösterilecek ürünler
  isFeatured     Boolean  @default(false)
  featuredOrder  Int      @default(0)
  collectionId   String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  variants   Variant[]
  images     Image[]

  @@index([collectionId])
  @@index([isPublished, sortOrder])
  @@index([isFeatured, featuredOrder])
  @@map("products")
}

/// Renk / malzeme varyantı
model Variant {
  id         String   @id @default(cuid())
  productId  String
  name       String
  nameEn     String?
  color      String?
  material   String?
  materialEn String?
  sku       String?  @unique
  sortOrder Int      @default(0)
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("variants")
}

/// Ürün görseli (galeri)
model Image {
  id        String   @id @default(cuid())
  productId String
  url       String   @db.VarChar(2048)
  alt       String?
  altEn     String?
  sortOrder Int      @default(0)
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, sortOrder])
  @@map("images")
}
